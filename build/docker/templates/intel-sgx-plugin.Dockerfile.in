#define _ENTRYPOINT_ /usr/local/bin/intel_sgx_device_plugin
ARG CMD=sgx_plugin

#include "default_plugin.docker"

LABEL name='intel-sgx-plugin'
LABEL org.opencontainers.image.title='Intel® SGX device plugin for Kubernetes'
LABEL org.opencontainers.image.description='The SGX device plugin is responsible for discovering and reporting SGX device nodes to kubelet'
