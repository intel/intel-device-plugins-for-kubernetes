#define _ENTRYPOINT_ /usr/local/bin/intel_gpu_device_plugin
ARG CMD=gpu_plugin

#include "default_plugin.docker"

LABEL name='intel-gpu-plugin'
LABEL org.opencontainers.image.title='Intel® GPU device plugin for Kubernetes'
LABEL org.opencontainers.image.description='The GPU device plugin provides access to Intel discrete (Xe) and integrated GPU HW device files'
