ARG FINAL_BASE_DYN=registry.access.redhat.com/ubi9/ubi:latest

FROM ${FINAL_BASE_DYN}

ARG UBI

COPY ./LICENSE /licenses/intel-device-plugins-for-kubernetes/LICENSE

RUN if [ $UBI -eq 0 ]; then \N
    echo "deb-src http://deb.debian.org/debian unstable main" >> \N
    /etc/apt/sources.list.d/deb-src.list; \N
    apt-get update && apt-get install -y --no-install-recommends accel-config jq && rm -rf /var/lib/apt/lists/\*; \N
    else \N
    dnf install --setopt=install_weak_deps=False --setopt=tsflags=nodocs -y accel-config jq && dnf -y autoremove && \N
    dnf clean all && rm -rf /var/cache/dnf; fi
RUN cd /licenses/intel-device-plugins-for-kubernetes
RUN if [ $UBI -eq 0 ]; then apt-get source --download-only -y accel-config; \N
    else dnf install -y dnf-plugins-core && dnf download --source accel-config && \N
    dnf remove -y dnf-plugins-core && dnf -y autoremove && dnf clean all && rm -rf /var/cache/dnf; fi

COPY demo/idxd-init.sh /usr/local/bin/
COPY demo/dsa.conf /idxd-init/
COPY demo/iaa.conf /idxd-init/

RUN mkdir /idxd-init/scratch

WORKDIR /idxd-init
ENTRYPOINT ["/usr/local/bin/idxd-init.sh"]

